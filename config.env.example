NODE_ENV=development
PORT=3000

# MongoDB Atlas connection string (replace <PASSWORD> with your DB user password)
DATABASE=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/natours?retryWrites=true&w=majority
DATABASE_LOCAL=mongodb://localhost:27017/natours
DATABASE_PASSWORD=your_database_password

# JWT
JWT_SECRET=your_long_random_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Mailtrap (development email)
EMAIL_USERNAME=your_mailtrap_username
EMAIL_PASSWORD=your_mailtrap_password
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=25

# Sender address for transactional emails
EMAIL_FROM=you@example.com

# SendGrid (production email)
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=your_sendgrid_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Mapbox
MAPBOX_TOKEN=pk.your_mapbox_public_token
