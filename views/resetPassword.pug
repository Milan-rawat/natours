extends base

block content
    main.main
        .login-form
            h2.heading-secondary.ma-bt-lg Reset your password
            form.form.form--reset-password#reset-password-form(data-token=`${resetToken}`)
                .form__group
                    label.form__label(for='password') New password
                    input#password.form__input(type='password', placeholder='••••••••', required, minlength='8')
                .form__group.ma-bt-md
                    label.form__label(for='passwordConfirm') Confirm new password
                    input#passwordConfirm.form__input(type='password', placeholder='••••••••', required, minlength='8')
                .form__group
                    button.btn.btn--green#btn-reset-password Save new password

block scripts
    script.
        (function () {
            var form = document.getElementById('reset-password-form');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                var token           = form.dataset.token;
                var password        = document.getElementById('password').value;
                var passwordConfirm = document.getElementById('passwordConfirm').value;
                var btn             = document.getElementById('btn-reset-password');

                if (password !== passwordConfirm) {
                    return Swal.fire({ icon: 'error', title: 'Passwords do not match', confirmButtonColor: '#55c57a' });
                }

                btn.textContent = 'Saving...';
                btn.disabled    = true;

                fetch('/api/v1/users/resetPassword/' + token, {
                    method:  'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ password: password, passwordConfirm: passwordConfirm })
                })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (data.status === 'success') {
                        Swal.fire({
                            icon:              'success',
                            title:             'Password updated!',
                            text:              'You are now logged in.',
                            confirmButtonColor: '#55c57a'
                        }).then(function () {
                            window.location.assign('/');
                        });
                    } else {
                        throw new Error(data.message || 'Token is invalid or has expired.');
                    }
                })
                .catch(function (err) {
                    btn.textContent = 'Save new password';
                    btn.disabled    = false;
                    Swal.fire({
                        icon:              'error',
                        title:             'Error',
                        text:              err.message,
                        confirmButtonColor: '#55c57a'
                    });
                });
            });
        })();
